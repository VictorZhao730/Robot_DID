{
  "name": "robot-did-project",
  "version": "1.0.0",
  "description": "Decentralized digital identity prototype for robots on UZHETH PoS.",
  "main": "hardhat.config.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.js --network uzhethpos",
    "register": "hardhat run scripts/registerRobot.js --network uzhethpos",
    "check": "hardhat run scripts/checkRobot.js --network uzhethpos",
    "suspend": "hardhat run scripts/suspendRobot.js --network uzhethpos",
    "unsuspend": "hardhat run scripts/unsuspendRobot.js --network uzhethpos",
    "rotate": "hardhat run scripts/rotateRobotKey.js --network uzhethpos",
    "transfer:nft": "hardhat run scripts/transferRobotNft.js --network uzhethpos",
    "controller": "hardhat run scripts/manageController.js --network uzhethpos",
    "revoke": "hardhat run scripts/revokeRobot.js --network uzhethpos",
    "minter:check": "hardhat run scripts/checkMinterRole.js --network uzhethpos",
    "minter:grant": "hardhat run scripts/grantMinterRole.js --network uzhethpos",
    "minter:revoke": "hardhat run scripts/revokeMinterRole.js --network uzhethpos",
    "issuer:admin:grant": "hardhat run scripts/grantIssuerRegistryAdmin.js --network uzhethpos",
    "issuer:register": "hardhat run scripts/registerIssuer.js --network uzhethpos",
    "issuer:grant": "hardhat run scripts/grantIssuerRole.js --network uzhethpos",
    "issuer:revoke": "hardhat run scripts/revokeIssuer.js --network uzhethpos",
    "issue": "node issuer/issueCredentialForRobot.js",
    "issue:self": "node robot/issueSelfSignedCredential.js",
    "issue:controller": "node controller/issueDelegatedCredential.js",
    "issue:issuer": "node issuer/issueCredentialForRobot.js",
    "anchor": "hardhat run scripts/anchorCredential.js --network uzhethpos",
    "consume": "hardhat run scripts/consumeCredential.js --network uzhethpos",
    "revoke:credential": "hardhat run scripts/revokeCredential.js --network uzhethpos",
    "verify": "node verifier/verifyCredential.js credentials/RobotSensorDataCredential.json",
    "ui": "node -e \"console.log('Open ui/index.html in your browser')\""
  },
  "keywords": [
    "did",
    "verifiable-credentials",
    "robots",
    "hardhat",
    "ethers"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "hardhat": "^2.26.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "dotenv": "^17.2.3",
    "ethers": "^6.15.0"
  }
}
